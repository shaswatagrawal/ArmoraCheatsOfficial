<%- include('partials/head', { title: 'Support' }) %>
<body>
  <%- include('partials/loader') %>
  <%- include('partials/header') %>
  
  <main>
      <section class="hero" id="support">
        <div class="hero-inner">
          <div class="hero-content">
            <p class="hero-tag">Support Center</p>
            <h1>Need help with Armora Cheats?</h1>
            <p class="hero-subtitle">
              We’re here to help with installation, billing questions, and
              troubleshooting so you can get back in‑game as fast as possible.
            </p>
          </div>
          <div class="hero-card">
            <div class="hero-card-body">
              <h2>Open a Support Ticket</h2>
              <p>Use our primary support channel for all account‑related issues.</p>
              <a href="https://discord.gg/zPwnj9mb6c" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-block">Open Ticket via Discord</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Common Issues</h2>
          <p>Quick tips for the most frequent problems.</p>
        </div>
        <div class="grid" style="max-width: 980px;">
          <article class="card">
            <h3>Loader won’t start</h3>
            <ul>
              <li>Run the loader as Administrator.</li>
              <li>Disable antivirus or add the loader to your exclusions.</li>
              <li>Make sure you are on Windows 10 or 11 (64‑bit).</li>
              <li>Install or update .NET Framework 4.8+.</li>
            </ul>
          </article>
          <article class="card">
            <h3>Key or HWID issues</h3>
            <ul>
              <li>Double‑check you copied your key correctly.</li>
              <li>
                If you changed hardware, you may need an HWID reset (subject to
                our rules).
              </li>
              <li>Contact support with proof of purchase.</li>
            </ul>
          </article>
          <article class="card">
            <h3>Crashes or game not injecting</h3>
            <ul>
              <li>Close unnecessary overlays or recording software.</li>
              <li>Verify your game files and restart your PC.</li>
              <li>Ensure your product is updated and supported for that game.</li>
            </ul>
          </article>
        </div>
      </section>
    </main>
  
  <%- include('partials/footer') %>
