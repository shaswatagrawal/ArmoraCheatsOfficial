<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= locals.title ? title + " - Armora Cheats" : "Armora Cheats" %></title>
    <meta
      name="description"
      content="Armora Cheats – premium, undetected game enhancements with top-tier security and support."
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script>
      // Global Auth Check for Armora Access
      (function() {
        const urlParams = new URLSearchParams(window.location.search);
        
        // If coming back from a SUCCESSFUL backend sync
        if (urlParams.get('login') === 'success') {
           localStorage.setItem('armora_auth', 'true');
           const userData = {
             username: urlParams.get('user'),
             avatar_url: urlParams.get('avatar')
           };
           localStorage.setItem('armora_user', JSON.stringify(userData));
        }
        
        // Universal flag for all pages
        window.isArmoraAuth = localStorage.getItem('armora_auth') === 'true';

        // URL Cleanup for auth tokens and errors
        const cleanParams = ['login', 'user', 'avatar', 'error', 'code'];
        let needsClean = false;
        
        // Save error for error reporting on any page land
        window.urlError = urlParams.get('error');
        
        cleanParams.forEach(p => { if (urlParams.has(p)) needsClean = true; });

        if (needsClean) {
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
        }
      })();

      // Client-Side Discord Auth Router (Universal Fix for Static and Server Hosting)
      function handleDiscordLogin() {
          const clientId = '1483970245222994093';
          const host = window.location.host;
          const protocol = (host.includes('localhost') || host.includes('127.0.0.1')) ? 'http' : 'https';
          const redirectUri = `${protocol}://${host}/callback`;

          const params = new URLSearchParams({
              client_id: clientId,
              redirect_uri: redirectUri,
              response_type: 'code',
              scope: 'identify'
          });
          window.location.href = `https://discord.com/api/oauth2/authorize?${params.toString()}`;
      }
    </script>
  </head>