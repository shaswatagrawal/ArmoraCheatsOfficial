    <script>
      function toggleUserDropdown() {
        const menu = document.getElementById('user-dropdown-menu');
        menu.classList.toggle('active');
      }

      function logoutUser() {
        localStorage.removeItem('armora_auth');
        localStorage.removeItem('armora_user');
        window.location.href = '/';
      }

      // Live Header Update logic
      (function() {
        // Initialize immediately if authed
        const updateHeader = () => {
          if (window.isArmoraAuth) {
             const loginBtn = document.getElementById('login-btn-nav');
             const profileNav = document.getElementById('user-profile-nav');
             if (loginBtn) loginBtn.style.display = 'none';
             if (profileNav) profileNav.style.display = 'flex';
             
             // Check for saved user info
             const savedUser = localStorage.getItem('armora_user');
             if (savedUser) {
               const userData = JSON.parse(savedUser);
               const nameEl = document.getElementById('user-display-name');
               const avatarEl = document.getElementById('user-avatar-img');
               if (nameEl) nameEl.textContent = userData.username;
               if (avatarEl) avatarEl.src = userData.avatar_url;
             }
          }
        };

        // Run once on load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', updateHeader);
        } else {
          updateHeader();
        }

        // Keep a small interval just in case window.isArmoraAuth changes without page reload 
        // (though unlikely in current setup)
        const checkAuth = setInterval(() => {
          if (window.isArmoraAuth) {
            updateHeader();
            clearInterval(checkAuth);
          }
        }, 1000);
      })();
    </script>

  </header>
