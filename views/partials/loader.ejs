<!-- High-Performance Premium Preloader -->
<div id="armora-preloader" class="preloader-overlay">
  <style>
    :root {
      --accent: #ff3e3e;
      --accent-glow: rgba(255, 62, 62, 0.5);
      --bg-dark: #050508;
    }

    .preloader-overlay {
      position: fixed;
      inset: 0;
      background: var(--bg-dark);
      z-index: 9999999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      transition: all 0.8s cubic-bezier(0.85, 0, 0.15, 1);
    }

    /* Cinematic Background */
    .preloader-bg {
      position: absolute;
      inset: 0;
      background: 
        radial-gradient(circle at 50% 50%, rgba(255, 62, 62, 0.08) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(255, 62, 62, 0.03) 0%, transparent 30%);
      filter: blur(80px);
    }

    /* Orbital System */
    .orbital-container {
      position: relative;
      width: 200px;
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-core {
      width: 100px;
      height: 100px;
      position: relative;
      z-index: 10;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 40px rgba(0,0,0,0.5);
      animation: core-pulse 2s ease-in-out infinite;
    }

    .logo-core img {
      width: 70%;
      height: 70%;
      object-fit: contain;
      filter: drop-shadow(0 0 10px var(--accent-glow));
    }

    .ring {
      position: absolute;
      border-radius: 50%;
      border: 2px solid transparent;
      border-top-color: var(--accent);
      filter: drop-shadow(0 0 8px var(--accent-glow));
    }

    .ring-1 { width: 140px; height: 140px; animation: spin 2s linear infinite; opacity: 0.8; }
    .ring-2 { width: 170px; height: 170px; animation: spin 3s linear reverse infinite; opacity: 0.5; border-top-color: #fff; }
    .ring-3 { width: 200px; height: 200px; animation: spin 4s linear infinite; opacity: 0.3; }

    /* Text & Info */
    .loader-brand {
      margin-top: 40px;
      text-align: center;
    }

    .loader-title {
      color: #fff;
      font-family: 'Outfit', 'Inter', sans-serif;
      font-size: 2.2rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 5px;
      background: linear-gradient(180deg, #fff 0%, #999 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      opacity: 0;
      transform: translateY(20px);
      animation: slide-up 0.8s ease forwards 0.3s;
    }

    .loader-status {
      color: var(--accent);
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.7;
      display: flex;
      align-items: center;
      gap: 10px;
      animation: fade-in 1s ease forwards 0.8s;
    }

    .loader-dots { display: flex; gap: 4px; }
    .dot { width: 4px; height: 4px; background: var(--accent); border-radius: 50%; animation: dot-pulse 1.5s infinite; }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }

    /* Progress Infrastructure */
    .progress-wrap {
      position: absolute;
      bottom: 60px;
      width: 280px;
    }

    .progress-track {
      height: 2px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    }

    .progress-fill {
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 0%;
      background: var(--accent);
      box-shadow: 0 0 15px var(--accent);
      transition: width 0.4s cubic-bezier(0.1, 0.7, 0.1, 1);
    }

    /* Animations */
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes core-pulse { 0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(0,0,0,0.5); } 50% { transform: scale(1.05); box-shadow: 0 0 40px var(--accent-glow); } }
    @keyframes slide-up { to { opacity: 1; transform: translateY(0); } }
    @keyframes fade-in { to { opacity: 0.7; } }
    @keyframes dot-pulse { 0%, 100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 1; transform: scale(1.2); } }

    .preloader-hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(1.1);
    }
  </style>

  <div class="preloader-bg"></div>

  <div class="orbital-container">
    <div class="ring ring-1"></div>
    <div class="ring ring-2"></div>
    <div class="ring ring-3"></div>
    <div class="logo-core">
      <img src="/logo/ARMORACHEATS.gif" alt="Logo">
    </div>
  </div>

  <div class="loader-brand">
    <h1 class="loader-title">ARMORA</h1>
    <div class="loader-status">
      Establishing Secure Link
      <div class="loader-dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
    </div>
  </div>

  <div class="progress-wrap">
    <div class="progress-track">
      <div class="progress-fill" id="preloader-progress"></div>
    </div>
  </div>

  <script>
    (function() {
      const bar = document.getElementById('preloader-progress');
      const overlay = document.getElementById('armora-preloader');
      let progress = 0;
      
      // Artificial smoothness
      const interval = setInterval(() => {
        progress += Math.random() * 15;
        if (progress > 100) progress = 100;
        
        bar.style.width = progress + '%';

        if (progress === 100) {
          clearInterval(interval);
          setTimeout(() => {
            overlay.classList.add('preloader-hidden');
            document.body.style.overflow = 'auto';
            
            // Cleanup
            setTimeout(() => {
              overlay.remove();
            }, 1000);
          }, 400);
        }
      }, 250);

      // Lock scroll while loading
      document.body.style.overflow = 'hidden';
      
      // Fail-safe
      window.addEventListener('load', () => {
        progress = 100;
      });
    })();
  </script>
</div>