<%- include('partials/head', { title: 'Internal' }) %>
<body>
  <%- include('partials/loader') %>
  <%- include('partials/header') %>
  
  <main>
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-content">
            <p class="hero-tag">Product · Internal</p>
            <h1>Armora Internal</h1>
            <p class="hero-subtitle">
              Direct injection internal build with responsive aimbot, ESP, and
              advanced in‑game configuration options.
            </p>
            <div class="hero-actions">
              <a href="/#pricing" class="btn btn-primary btn-lg">View Pricing</a>
              <a href="/#download" class="btn btn-ghost btn-lg">Download Loader</a>
            </div>
          </div>
          <div class="hero-card">
            <div class="hero-card-body">
              <h2>Showcase Video</h2>
              <p>Gameplay preview of Armora Internal.</p>
              <div class="card" style="padding: 0; overflow: hidden;">
                <iframe
                  width="100%"
                  height="260"
                  src="https://www.youtube-nocookie.com/embed/Cdtaz2vB0rU"
                  title="Armora Internal Showcase"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
              <a
                href="https://www.youtube.com/@armoracheatsofficial"
                class="btn btn-outline btn-block"
                target="_blank"
                rel="noopener noreferrer"
                >Visit Official YouTube</a
              >
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Highlights</h2>
          <p>Why players choose the internal build.</p>
        </div>
        <div class="grid" style="max-width: 980px;">
          <article class="card">
            <h3 style="margin-bottom: 0.5rem;">⚡ Aimbot Function</h3>
            <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.95rem; opacity: 0.9; line-height: 1.6;">
              <li>Aimbot Visible</li>
              <li>Aimbot Rage</li>
              <li>Ignore Knock</li>
              <li>Ignore Bot</li>
              <li>AimFov</li>
            </ul>
          </article>
          <article class="card">
            <h3 style="margin-bottom: 0.5rem;">⚡ Visuals Function</h3>
            <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.95rem; opacity: 0.9; line-height: 1.6;">
              <li>ESP Distance</li>
              <li>ESP Wukong</li>
              <li>ESP Line (Up/Down)</li>
              <li>ESP Glow (Glow Radius/Glow Feather/Line Thickness)</li>
              <li>ESP Box (Full Box / Cornered Box)</li>
              <li>ESP Health (Left/Right/Down/Text)</li>
              <li>ESP Level</li>
              <li>ESP Skeleton</li>
              <li>ESP Near Count</li>
              <li>ESP Weapon</li>
              <li>ESP Weapon Icon</li>
              <li>ESP Moco</li>
            </ul>
          </article>
          <article class="card">
            <h3 style="margin-bottom: 0.5rem;">⚡ Settings Function</h3>
            <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.95rem; opacity: 0.9; line-height: 1.6;">
              <li>Keybind Supported</li>
              <li>Stream Mode</li>
              <li>Pin to Top</li>
              <li>Unload Internal Function</li>
            </ul>
          </article>
          <article class="card">
            <h3 style="margin-bottom: 0.5rem;">⚡ Regarding Panel</h3>
            <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.95rem; opacity: 0.9; line-height: 1.6;">
              <li>All Server Safe</li>
              <li>Regular Updates</li>
              <li>Fastest Support</li>
              <li>User Friendly UI</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section" id="pricing">
        <div class="section-header">
          <h2>Pricing</h2>
          <p>Choose the plan that suits your needs.</p>
        </div>
        <div class="grid pricing-grid" style="display: flex; justify-content: center;">
          <article class="card pricing-card" style="max-width: 350px;">
            <h3>Armora Internal</h3>
            <p class="price-note">Standard internal build.</p>
            <ul>
              <li>30 Days – <strong>$10</strong></li>
              <li>90 Days – <strong>$18</strong></li>
              <li>Lifetime – <strong>$30</strong></li>
            </ul>
            <a href="/#download" class="btn btn-outline btn-block">Purchase Internal</a>
          </article>
        </div>
      </section>
    </main>
  
  <%- include('partials/footer') %>
