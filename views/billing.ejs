<%- include('partials/head', { title: 'Billing & Checkout' }) %>
<body>
  <%- include('partials/loader') %>
  <div class="bg-mesh"></div>
  <div class="noise"></div>
  <%- include('partials/header') %>
  
  <main class="section" style="padding-top: 160px;">
    <div class="section-header reveal active">
      <p class="hero-tag">Secure Checkout</p>
      <h1>Invoice & Billing</h1>
      <p>Configure your plan and generate your official receipt after payment. Fast, secure, and transparent.</p>
    </div>

    <div class="grid" style="grid-template-columns: 1.6fr 1fr; align-items: start; gap: 3rem; max-width: 1200px; margin: 0 auto;">
        <!-- Left: Form -->
        <section class="card reveal active" style="padding: 2.5rem;">
            <h3 style="margin-bottom: 2rem; display: flex; align-items: center; gap: 0.8rem; font-family: var(--font-display); font-size: 1.5rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 8h10M7 12h10M7 16h10"/></svg>
                Customer Details
            </h3>
            
            <form id="billingForm" class="billing-form">
                <div class="form-group">
                    <label>Full Name or Discord Tag</label>
                    <input type="text" id="customerName" placeholder="e.g. Ghost#1337" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Select Product</label>
                        <select id="productSelect" required>
                            <option value="external">Armora External</option>
                            <option value="premium">Armora Premium</option>
                            <option value="internal">Armora Internal</option>
                            <option value="internal-x64">Armora Internal x64</option>
                            <option value="uid-bypass">Armora UID Bypass</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Duration</label>
                        <select id="planSelect" required>
                            <!-- Options filled by JS -->
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Payment Method</label>
                    <div class="payment-methods">
                        <label class="method-option">
                            <input type="radio" name="paymentMethod" value="esewa" checked>
                            <div class="method-box">
                                <img src="https://esewa.com.np/common/images/esewa_logo.png" alt="eSewa">
                                <span>eSewa (NPR)</span>
                            </div>
                        </label>
                        <label class="method-option">
                            <input type="radio" name="paymentMethod" value="upi">
                            <div class="method-box">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/f/fa/UPI-Logo.png" alt="UPI">
                                <span>UPI (INR)</span>
                            </div>
                        </label>
                        <label class="method-option">
                            <input type="radio" name="paymentMethod" value="binance">
                            <div class="method-box">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/12/Binance_logo.svg/1280px-Binance_logo.svg.png" alt="Binance">
                                <span>Binance (USDT)</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 2rem;">
                    <button type="submit" class="btn btn-primary btn-block btn-lg" id="generateBtn" style="padding: 1.25rem;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        Lock Selection & Show QR
                    </button>
                </div>
            </form>
        </section>

        <!-- Right: Summary & QR -->
        <aside class="billing-summary reveal active">
            <div class="card" id="summaryCard" style="border-radius: 32px; border-color: var(--border-primary);">
                <h3 style="margin-bottom: 1.5rem; font-family: var(--font-display);">Order Summary</h3>
                <div class="summary-details">
                    <div class="summary-line">
                        <span>Product</span>
                        <span id="sumProduct" style="color: #fff; font-weight: 600;">-</span>
                    </div>
                    <div class="summary-line">
                        <span>Plan Duration</span>
                        <span id="sumPlan" style="color: #fff; font-weight: 600;">-</span>
                    </div>
                    <div class="summary-line highlight">
                        <span>Total Due</span>
                        <span id="sumTotal" style="color: var(--primary);">$0.00</span>
                    </div>
                </div>

                <div id="qrContainer" class="qr-display" style="display: none;">
                    <div class="qr-box" id="qrWrapper" style="background: #fff; padding: 15px; border-radius: 12px; margin: 0 auto;">
                        <div id="paymentQR" style="display: flex; justify-content: center;"></div>
                        <div class="qr-status">
                            <div class="spinner"></div>
                            <span id="qrStatusText">Awaiting Payment...</span>
                        </div>
                    </div>
                    <p class="qr-note" id="instructionText">
                        <span style="display: block; color: #ff3e3e; font-weight: 800; border: 1px dashed #ff3e3e; padding: 10px; border-radius: 8px; margin-bottom: 12px;">
                            ⚠️ PAY EXACT AMOUNT: Any deviation will result in automated verification failure.
                        </span>
                        Scan this QR with your payment app. The amount is pre-filled/encoded for your security.
                    </p>
                    
                    <!-- Payment Verification Button -->
                    <button class="btn btn-primary btn-block btn-lg" id="verifyPaymentBtn" style="margin-top: 1rem; background: var(--primary); color: #000; border: none; font-weight: 800;">
                        I Have Completed Payment
                    </button>

                    <!-- Hidden Success Section -->
                    <div id="successSection" style="display: none; margin-top: 1.5rem; text-align: center; border-top: 2px solid var(--border-primary); padding-top: 1.5rem;">
                        <h4 style="color: #4ade80; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; gap: 8px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Confirmed & Verified
                        </h4>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <button class="btn btn-primary btn-block" id="downloadReceiptBtn" style="background: #fff; color: #000; border: none; font-size: 0.8rem; padding: 0.8rem;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="stroke: #000;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Receipt
                            </button>
                            <a href="https://discord.gg/zPwnj9mb6c" target="_blank" class="btn btn-primary btn-block" style="font-size: 0.8rem; padding: 0.8rem;">
                                Claim Product
                            </a>
                        </div>
                        <p id="redirectText" style="font-size: 0.75rem; color: var(--text-dim); margin-top: 1rem;">Redirecting to Discord in <span id="countdown">5</span>s...</p>
                    </div>

                    <p style="font-size: 0.75rem; color: var(--text-dim); margin-top: 1rem; text-align: center;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Secure transaction via ARMORA Network
                    </p>
                </div>
            </div>
        </aside>
    </div>

    <!-- Instructions -->
    <section class="section reveal active" style="margin-top: 4rem; padding-top: 0;">
        <div class="card" style="max-width: 800px; margin: 0 auto; padding: 2rem;">
            <h3>Helpful Information</h3>
            <ul class="product-list" style="margin-top: 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <li>Exact amounts must be paid to ensure auto-verification.</li>
                <li>Receipts are generated locally for your security.</li>
                <li>Upload the generated PDF to our Discord ticket for instant delivery.</li>
                <li>Crypto payments (USDT) are processed on the TRC20 network.</li>
            </ul>
        </div>
    </section>
  </main>

  <style>
    .billing-form .form-group { margin-bottom: 1.8rem; }
    .billing-form label { display: block; margin-bottom: 0.7rem; color: var(--text-dim); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; }
    .billing-form input, .billing-form select { 
        width: 100%; padding: 1rem 1.2rem; border-radius: 12px; 
        background: rgba(255,255,255,0.03); border: 1px solid var(--border-white); 
        color: #fff; font-family: var(--font-body); font-size: 1rem;
        transition: all 0.3s ease;
    }
    .billing-form input:focus, .billing-form select:focus {
        border-color: var(--primary);
        background: rgba(255, 62, 62, 0.05);
        outline: none;
        box-shadow: 0 0 20px rgba(255, 62, 62, 0.1);
    }
    .form-row { display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; }
    
    .payment-methods { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 0.5rem; }
    .method-option input { display: none; }
    .method-box { 
        border: 1px solid var(--border-white); border-radius: 16px; padding: 1.5rem 0.5rem; 
        display: flex; flex-direction: column; align-items: center; gap: 0.8rem; cursor: pointer; transition: 0.3s;
        background: rgba(5, 5, 8, 0.4);
        height: 100%;
    }
    .method-box img { height: 40px; width: auto; max-width: 90%; object-fit: contain; transition: 0.3s; }
    .method-box span { font-size: 0.75rem; color: var(--text-dim); text-align: center; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    
    .method-option input:checked + .method-box { 
        border-color: var(--primary); 
        background: rgba(255, 62, 62, 0.12);
        box-shadow: 0 10px 20px -5px rgba(255, 62, 62, 0.2);
    }
    .method-option input:checked + .method-box span { color: #fff; }

    .summary-line { display: flex; justify-content: space-between; margin-bottom: 1.2rem; color: var(--text-dim); font-size: 1rem;}
    .summary-line.highlight { 
        margin-top: 1.5rem; padding-top: 1.5rem; 
        border-top: 1px solid var(--border-white); 
        color: #fff; font-weight: 800; font-size: 1.5rem; 
        font-family: var(--font-display);
    }
    
    .qr-display { margin-top: 2rem; text-align: center; border-top: 1px dashed var(--border-white); padding-top: 2rem; }
    .qr-box { 
        position: relative; 
        display: inline-block; 
        padding: 18px; 
        background: #fff; 
        border-radius: 20px; 
        margin-bottom: 1.5rem; 
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        border: 4px solid var(--primary);
    }
    .qr-box img { width: 220px; height: 220px; display: block; border-radius: 8px; }
    .qr-status { 
        position: absolute; bottom: -12px; left: 50%; 
        transform: translateX(-50%); 
        background: #050508; color: #fff;
        padding: 6px 16px; border-radius: 20px; 
        font-size: 0.75rem; border: 1px solid var(--border-primary); 
        display: flex; align-items: center; gap: 8px; white-space: nowrap;
        font-weight: 700;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }
    .qr-note { font-size: 0.9rem; color: var(--text-dim); margin: 1rem 0; line-height: 1.5; }
    
    .spinner { width: 12px; height: 12px; border: 2px solid var(--primary); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s infinite linear; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 992px) {
        .grid { grid-template-columns: 1fr !important; }
        aside.billing-summary { order: -1; }
    }
    @media (max-width: 600px) {
        .payment-methods { grid-template-columns: 1fr; }
        .form-row { grid-template-columns: 1fr; }
    }
  </style>

  <!-- jspdf -->

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>

  <script>
    const products = {
        'external': { name: 'Armora External', plans: { '30 Days': 10, '90 Days': 20, 'Lifetime': 40 } },
        'premium': { name: 'Armora Premium', plans: { '30 Days': 15, '90 Days': 30, 'Lifetime': 60 } },
        'internal': { name: 'Armora Internal', plans: { '30 Days': 10, '90 Days': 18, 'Lifetime': 30 } },
        'internal-x64': { name: 'Armora Internal x64', plans: { '30 Days': 10, '90 Days': 15, 'Lifetime': 30 } },
        'uid-bypass': { name: 'Armora UID Bypass', plans: { '1 Day': 1, '3 Days': 2.5, '7 Days': 6, '14 Days': 12, '1 Month': 20, 'Lifetime': 200 } }
    };

    const qrConfigs = {
        'esewa': { id: '9820742290', name: 'Armora Payment' },
        'upi': { vpa: 'macbhaiyt@oksbi', name: 'Armora Cheats' },
        'binance': { wallet: '1102116910', note: 'Binance Pay ID' }
    };

    const fx = { 'esewa': 135, 'upi': 85, 'binance': 1 }; 

    let qrcode = null;
    const form = document.getElementById('billingForm');
    const productSelect = document.getElementById('productSelect');
    const planSelect = document.getElementById('planSelect');
    
    function updatePlans() {
        const prod = products[productSelect.value];
        const prevValue = planSelect.value;
        planSelect.innerHTML = '';
        for (let [key, val] of Object.entries(prod.plans)) {
            let opt = document.createElement('option');
            opt.value = key;
            opt.textContent = `${key} - $${val}`;
            planSelect.appendChild(opt);
        }
        if (prevValue && prod.plans[prevValue]) planSelect.value = prevValue;
        updateSummary();
    }

    function updateSummary() {
        const prod = products[productSelect.value];
        const planKey = planSelect.value;
        if (!planKey) return;
        const price = prod.plans[planKey];
        const method = document.querySelector('input[name="paymentMethod"]:checked').value;
        
        document.getElementById('sumProduct').textContent = prod.name;
        document.getElementById('sumPlan').textContent = planKey;
        
        let currency = '$';
        let finalPrice = price;
        if (method === 'esewa') { currency = 'NPR '; finalPrice = (price * fx.esewa).toLocaleString(); }
        else if (method === 'upi') { currency = 'INR '; finalPrice = (price * fx.upi).toLocaleString(); }
        else { currency = 'USDT '; finalPrice = price; }
        
        document.getElementById('sumTotal').textContent = `${currency}${finalPrice}`;
        
        // Static QR Display
        const qrElement = document.getElementById('paymentQR');
        qrElement.innerHTML = ''; // Clear
        
        const qrImg = document.createElement('img');
        qrImg.style.width = '220px';
        qrImg.style.height = '220px';
        qrImg.style.objectFit = 'contain';
        qrImg.style.borderRadius = '8px';

        if (method === 'upi') {
            qrImg.src = '/payment/upi.jpg';
            document.querySelector('.qr-note').innerHTML = `Scan to pay <strong>INR ${finalPrice}</strong> to MacBhai.`;
        } else if (method === 'binance') {
            qrImg.src = '/payment/binance.png';
            document.querySelector('.qr-note').innerHTML = `Pay exactly <strong>$${price} USDT</strong> to Binance ID: 1102116910`;
        } else {
            qrImg.src = '/payment/esewa.jpg';
            document.querySelector('.qr-note').innerHTML = `Send <strong>NPR ${finalPrice}</strong> to eSewa: 9820742290`;
        }
        qrElement.appendChild(qrImg);
    }

    productSelect.addEventListener('change', updatePlans);
    planSelect.addEventListener('change', updateSummary);
    document.querySelectorAll('input[name="paymentMethod"]').forEach(r => r.addEventListener('change', updateSummary));

    // Handle initial state from query params
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('product')) {
        productSelect.value = urlParams.get('product');
    }
    updatePlans();

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const customer = document.getElementById('customerName').value;
        if (!customer) return;

        document.getElementById('qrContainer').style.display = 'block';
        const btn = document.getElementById('generateBtn');
        btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;"><polyline points="20 6 9 17 4 12"></polyline></svg> Selection Fixed';
        btn.style.background = 'rgba(255,255,255,0.05)';
        btn.style.color = 'var(--text-dim)';
        btn.disabled = true;
        
        // Disable form inputs
        document.getElementById('customerName').disabled = true;
        productSelect.disabled = true;
        planSelect.disabled = true;
        document.querySelectorAll('input[name="paymentMethod"]').forEach(r => r.disabled = true);

        // Smooth scroll to QR
        window.scrollTo({
            top: document.getElementById('qrContainer').offsetTop - 200,
            behavior: 'smooth'
        });
    });

    // Payment Verification & Discord Redirect
    document.getElementById('verifyPaymentBtn').addEventListener('click', function() {
        const btn = this;
        btn.innerHTML = '<div class="spinner" style="display:inline-block; margin-right:8px;"></div> Verifying Transaction...';
        btn.disabled = true;
        btn.style.opacity = '0.7';

        document.getElementById('qrStatusText').textContent = 'Confirming on Chain...';

        setTimeout(() => {
            btn.style.display = 'none';
            document.getElementById('instructionText').style.display = 'none';
            document.getElementById('successSection').style.display = 'block';
            document.getElementById('qrStatusText').textContent = 'Transaction Confirmed';
            document.getElementById('qrStatusText').style.color = '#4ade80';

            // Start Countdown
            let timeLeft = 5;
            const countdownEl = document.getElementById('countdown');
            const timer = setInterval(() => {
                timeLeft--;
                countdownEl.textContent = timeLeft;
                if (timeLeft <= 0) {
                    clearInterval(timer);
                    window.location.href = "https://discord.gg/zPwnj9mb6c";
                }
            }, 1000);
        }, 2500);
    });

    // Premium PDF Generation
    document.getElementById('downloadReceiptBtn').addEventListener('click', () => {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();
        
        const customer = document.getElementById('customerName').value;
        const prod = products[productSelect.value].name;
        const plan = planSelect.options[planSelect.selectedIndex].text.split(' - ')[0];
        const method = document.querySelector('input[name="paymentMethod"]:checked').value.toUpperCase();
        const total = document.getElementById('sumTotal').textContent;
        const date = new Date().toLocaleString();
        const invoiceNo = 'ARM-' + Math.floor(Math.random() * 900000 + 100000);

        // Styling Config
        const accent = [255, 62, 62]; // #ff3e3e
        const dark = [5, 5, 8];

        // Header
        doc.setFillColor(...dark);
        doc.rect(0, 0, 210, 50, 'F');
        
        doc.setTextColor(...accent);
        doc.setFontSize(28);
        doc.setFont("helvetica", "bold");
        doc.text("ARMORA CHEATS", 20, 30);
        
        doc.setTextColor(150, 150, 150);
        doc.setFontSize(10);
        doc.setFont("helvetica", "normal");
        doc.text("PREMIUM GAMING ENHANCEMENTS", 20, 38);
        
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(12);
        doc.text("OFFICIAL RECEIPT", 155, 30);
        doc.setFontSize(10);
        doc.text(invoiceNo, 155, 38);

        // Border Line
        doc.setDrawColor(...accent);
        doc.setLineWidth(1);
        doc.line(20, 55, 190, 55);

        // Info Grid
        doc.setTextColor(0, 0, 0);
        doc.setFontSize(11);
        doc.setFont("helvetica", "bold");
        doc.text("BILLED TO", 20, 75);
        doc.setFont("helvetica", "normal");
        doc.text(customer, 20, 83);
        
        doc.setFont("helvetica", "bold");
        doc.text("ISSUE DATE", 80, 75);
        doc.setFont("helvetica", "normal");
        doc.text(date.split(',')[0], 80, 83);
        
        doc.setFont("helvetica", "bold");
        doc.text("EXPIRES", 140, 75);
        doc.setFont("helvetica", "normal");
        const expDate = new Date();
        expDate.setDate(expDate.getDate() + 30); // Placeholder
        doc.text(plan.includes('Lifetime') ? 'NEVER' : expDate.toLocaleDateString(), 140, 83);

        // Order Table
        doc.autoTable({
            startY: 100,
            head: [['Product', 'Subscription', 'Payment Via', 'Total Amount']],
            body: [[prod, plan, method, total]],
            headStyles: { fillColor: accent, textColor: [255, 255, 255], fontStyle: 'bold', halign: 'center' },
            bodyStyles: { halign: 'center', fontSize: 10 },
            columnStyles: { 0: { halign: 'left', fontStyle: 'bold' } },
            theme: 'striped',
            margin: { left: 20, right: 20 }
        });

        const finalY = doc.lastAutoTable.finalY || 130;
        
        // Footer Notes
        doc.setFont("helvetica", "bold");
        doc.setFontSize(10);
        doc.text("Important Instructions:", 20, finalY + 20);
        
        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        doc.setTextColor(80, 80, 80);
        const notes = [
            "1. Join our Discord server: discord.gg/zPwnj9mb6c",
            "2. Open a #support ticket and upload this PDF receipt.",
            "3. Staff will verify the transaction and deliver your license key.",
            "4. For crypto, please provide the TXID alongside this receipt."
        ];
        notes.forEach((note, i) => {
            doc.text(note, 20, finalY + 28 + (i * 6));
        });

        // Anti-Counterfeit Stamp
        doc.setDrawColor(...accent);
        doc.setLineWidth(0.5);
        doc.rect(140, finalY + 20, 50, 20);
        doc.setTextColor(...accent);
        doc.setFontSize(12);
        doc.setFont("helvetica", "bold");
        doc.text("VERIFIED", 152, finalY + 32);
        
        // Footer Branding
        doc.setFillColor(240, 240, 240);
        doc.rect(0, 280, 210, 17, 'F');
        doc.setFontSize(8);
        doc.setTextColor(150, 150, 150);
        doc.text("This receipt was generated by Armora Web Engine. All rights reserved.", 105, 290, { align: 'center' });

        doc.save(`${customer}_Armora_Receipt.pdf`);
    });
  </script>

  <%- include('partials/footer') %>
</body>
