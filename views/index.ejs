    .r-3 { inset: 20px; border: 1px dashed rgba(255, 255, 255, 0.1); }
    .core-logo { color: #fff; z-index: 2; filter: drop-shadow(0 0 15px rgba(255, 62, 62, 0.4)); animation: logo-float 4s ease-in-out infinite; }

