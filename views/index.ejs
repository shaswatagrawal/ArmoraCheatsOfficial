    .auth-title .highlight { color: #ff3e3e; text-shadow: 0 0 15px rgba(255, 62, 62, 0.3); }
    .auth-subtitle { font-size: 0.75rem; color: #4b5563; letter-spacing: 4px; font-weight: 500; }

    .gate-actions { margin-top: 3rem; }
    .btn-discord-gate {
      background: #5865F2; color: #fff; text-decoration: none;
      display: flex; align-items: center; justify-content: center; gap: 12px;
      padding: 1.2rem; border-radius: 12px; font-weight: 800; font-size: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 15px 35px -10px rgba(88, 101, 242, 0.4);
    }
    .btn-discord-gate:hover { transform: translateY(-4px) scale(1.02); background: #4a57da; box-shadow: 0 20px 50px -10px rgba(88, 101, 242, 0.6); }

    .terminal-footer { margin-top: 4rem; text-align: left; }
    .system-logs {
      background: rgba(0,0,0,0.4); border: 1px solid rgba(255, 255, 255, 0.03); border-radius: 12px;
      padding: 1.2rem; font-size: 0.7rem; color: #434c5e; height: 110px; overflow: hidden;
    }
    .log-entry { margin-bottom: 6px; font-family: var(--font-mono); opacity: 0; animation: log-slide 0.3s forwards; }

    @keyframes status-pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } }
    @keyframes logo-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @keyframes log-slide { to { opacity: 1; transform: translateX(0); } from { transform: translateX(-10px); } }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    .content-blur { filter: blur(60px); transition: filter 1.5s ease; }
    .content-reveal { filter: blur(0); }

    /* Custom Cursor Fix is already in styles.css */
    
    /* Section Partitions */
    .section-divider {
      height: 1px; width: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 62, 62, 0.2), transparent);
      position: relative; margin: 4rem 0;
    }
    .section-divider::after {
      content: ""; position: absolute; top: -4px; left: 50%; transform: translateX(-50%);
