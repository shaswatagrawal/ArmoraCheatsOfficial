  <script>
    // Triple-A Matrix Digital Background
    (function() {
      const canvas = document.getElementById('matrix-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = window.innerHeight;
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789$#@&%*";
      const drops = [];
      const fontSize = 14;
      const columns = w / fontSize;

      for (let i = 0; i < columns; i++) drops[i] = 1;

      window.addEventListener('resize', () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      });

      function draw() {
        ctx.fillStyle = "rgba(1, 2, 4, 0.05)";
        ctx.fillRect(0, 0, w, h);
        ctx.fillStyle = "#ff3e3e"; 
        ctx.font = fontSize + "px monospace";

        for (let i = 0; i < drops.length; i++) {
          const text = chars.charAt(Math.floor(Math.random() * chars.length));
          ctx.fillText(text, i * fontSize, drops[i] * fontSize);
          if (drops[i] * fontSize > h && Math.random() > 0.975) drops[i] = 0;
          drops[i]++;
        }
      }
      setInterval(draw, 50);

      // Terminal Log Interactivity
      const logs = [
        "> Syncing with secure shard [7] ...",
        "> Bypass detected ... Injecting identity...",
        "> Handshake complete. Waiting authorization...",
        "> System Integrity: 99.9%",
        "> Node status: [RED_ALERT]"
      ];
      let logIdx = 0;
      const logContainer = document.getElementById('terminal-logs');
      setInterval(() => {
        if (!logContainer) return;
        const div = document.createElement('div');
        div.className = 'log-entry';
        div.textContent = logs[logIdx % logs.length];
        logContainer.appendChild(div);
        if (logContainer.childNodes.length > 5) logContainer.removeChild(logContainer.firstChild);
        logIdx++;
      }, 4000);
    })();

    // Armora Terminal Coordination
    (function() {
      const gate = document.getElementById('security-gate');
      const main = document.querySelector('main');
      const errorDiv = document.getElementById('auth-error-msg');
      const errorText = document.getElementById('error-text');

      // Check for errors in URL (captured by head.ejs)
      const error = window.urlError;
      if (error && errorDiv && errorText) {
          errorDiv.style.display = 'block';
          if (error === 'auth_failed') errorText.textContent = 'ERROR: DISCORD_TOKEN_EXCHANGE_FAILED';
          else if (error === 'server_error') errorText.textContent = 'ERROR: INTERNAL_SERVER_CRASH';
          else if (error === 'profile_failed') errorText.textContent = 'ERROR: DISCORD_PROFILE_FETCH_FAILED';
          else errorText.textContent = `ERROR: ${error.toUpperCase()}`;
      }

      if (window.isArmoraAuth) {
          if (gate) {
            gate.classList.remove('active');
            setTimeout(() => { gate.style.display = 'none'; }, 1500); // Wait for transition
          }
          if (main) main.classList.add('content-reveal');
          document.body.style.overflow = 'auto';
      } else {
          // Gate is already active by default in HTML
          document.body.style.overflow = 'hidden';
          const loader = document.getElementById('armora-preloader');
          if (loader) loader.style.display = 'none';
      }
    })();
  </script>

  <style>
    /* Professional Triple-A Core Terminal */
    .gate-overlay {
      position: fixed; inset: 0; background: #010204; z-index: 2000000;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transition: all 1.5s cubic-bezier(0.8, 0, 0.2, 1);
      overflow: hidden;
    }
    .gate-overlay:not(.active) { transform: translateY(-100%); opacity: 0; pointer-events: none; }
    
    .terminal-bg { position: absolute; inset: 0; pointer-events: none; }
    .terminal-vignette { position: absolute; inset: 0; background: radial-gradient(circle, transparent 20%, #000 100%); z-index: 2; }
    .terminal-scanline {
      position: absolute; inset: 0; height: 100%; width: 100%;
      background: linear-gradient(to bottom, rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%);
      background-size: 100% 4px; z-index: 3; pointer-events: none; opacity: 0.1;
    }

    .gate-content { 
      position: relative; z-index: 10; max-width: 480px; width: 90%; 
      text-align: center; color: #fff; font-family: var(--font-mono);
    }

    .system-status-header {
      display: flex; align-items: center; justify-content: center; gap: 10px;
