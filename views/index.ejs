      border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 99px; width: fit-content; margin-inline: auto;
    }
    .status-indicator { width: 8px; height: 8px; background: #ff3e3e; border-radius: 50%; box-shadow: 0 0 10px #ff3e3e; animation: status-pulse 1s infinite; }
