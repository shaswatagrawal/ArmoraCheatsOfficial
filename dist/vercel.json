{
  "version": 2,
  "rewrites": [
    { "source": "/callback", "destination": "/api/callback" },
    { "source": "/payment", "destination": "/payment.html" },
    { "source": "/premium", "destination": "/premium.html" },
    { "source": "/external", "destination": "/external.html" },
    { "source": "/internal", "destination": "/internal.html" },
    { "source": "/internal-x64", "destination": "/internal-x64.html" },
    { "source": "/internal-x86", "destination": "/internal-x86.html" },
    { "source": "/uid-bypass", "destination": "/uid-bypass.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/refund", "destination": "/refund.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/billing", "destination": "/billing.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
